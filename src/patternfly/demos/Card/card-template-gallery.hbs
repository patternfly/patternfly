{{#> gallery gallery--modifier="pf-m-gutter"}}
  {{#> card card--id=(concat card-template-gallery--id '-card-empty-state') card--modifier="pf-m-selectable-raised pf-m-compact"}}
    {{#> bullseye}}
      {{#> empty-state empty-state--modifier="pf-m-xs"}}
        <i class="fas fa-plus-circle {{pfv}}empty-state__icon"></i>
        {{> card-title card-title-text--value="Add a new card to your page" card-title-text--modifier="pf-m-md"}}
        {{#> empty-state-secondary}}
          {{#> button button--IsLink=true}}
            Add card
          {{/button}}
        {{/empty-state-secondary}}
      {{/empty-state}}
    {{/bullseye}}
  {{/card}}
  {{#> card card--id=(concat card-template-gallery--id '-card-1') card--modifier="pf-m-selectable-raised pf-m-secondary pf-m-compact"}}
    {{#> card-header}}
      <img src="/assets/images/PF-IconLogo.svg" alt="PatternFly logo"> 
      {{#> card-actions}}
        {{> menu-toggle menu-toggle--IsPlain=true menu-toggle--HasKebab=true menu-toggle--id=(dasherize card--id "toggle")}}
        {{#> check check--modifier="pf-m-standalone"}}
          {{#> check-input check-input--attribute=(concat 'id="' card--id '-check" name="' card--id '-check" aria-labelledby="' card--id '-check-label"')}}{{/check-input}}
        {{/check}}
      {{/card-actions}}
    {{/card-header}}
    {{#> card-title card-title-text--value="Patternfly" card-title-text--id=(concat card--id '-check-label')}}
      {{#> content}}
        <small>Provided by Red Hat</small>
      {{/content}}
    {{/card-title}}
    {{#> card-body}}
        PatternFly is a community project that promotes design commonality and improves user experience.
    {{/card-body}}
  {{/card}}
  {{#> card card--id=(concat card-template-gallery--id '-card-2') card--modifier="pf-m-selectable-raised pf-m-compact"}}
    {{#> card-header}}
      <img src="/assets/images/activemq-core_200x150.png" width="60px" alt="Logo">
      {{#> card-actions}}
        {{> menu-toggle menu-toggle--IsPlain=true menu-toggle--HasKebab=true menu-toggle--id=(dasherize card--id "toggle")}}
        {{#> check check--modifier="pf-m-standalone"}}
          {{#> check-input check-input--attribute=(concat 'id="' card--id '-check" name="' card--id '-check" aria-labelledby="' card--id '-check-label"')}}{{/check-input}}
        {{/check}}
      {{/card-actions}}
    {{/card-header}}
    {{#> card-title card-title-text--value="ActiveMq" card-title-text--id=(concat card--id '-check-label')}}
      {{#> content}}
        <small>Provided by Red Hat</small>
      {{/content}}
    {{/card-title}}
    {{#> card-body}}
      The ActiveMQ component allows messages to be sent to a JMS Queue or Topic; or messages to be consumed from a JMS Queue or Topic using Apache ActiveMQ.
    {{/card-body}}
  {{/card}}
  {{#> card card--id=(concat card-template-gallery--id '-card-3') card--modifier="pf-m-selectable-raised pf-m-compact"}}
    {{#> card-header}}
      <img src="/assets/images/camel-spark_200x150.png" width="60px" alt="Logo">
      {{#> card-actions}}
        {{> menu-toggle menu-toggle--IsPlain=true menu-toggle--HasKebab=true menu-toggle--id=(dasherize card--id "toggle")}}
        {{#> check check--modifier="pf-m-standalone"}}
          {{#> check-input check-input--attribute=(concat 'id="' card--id '-check" name="' card--id '-check" aria-labelledby="' card--id '-check-label"')}}{{/check-input}}
        {{/check}}
      {{/card-actions}}
    {{/card-header}}
    {{#> card-title card-title-text--value="Apache Spark" card-title-text--id=(concat card--id '-check-label')}}
      {{#> content}}
        <small>Provided by Red Hat</small>
      {{/content}}
    {{/card-title}}
    {{#> card-body}}
      This documentation page covers the Apache Spark component for the Apache Camel.
    {{/card-body}}
  {{/card}}
{{/gallery}}
