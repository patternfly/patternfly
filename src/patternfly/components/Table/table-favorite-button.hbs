{{#>button
    button--IsPlain=true
    button--id=(dasherize table--id 'favorite-button' table-tr--index)
    button--aria-label=(ternary table-td--IsFavorited 'Starred' 'Not starred')
    button--aria-labelledby=(dasherize table--id 'node' table-tr--index table--id 'favorite-button' table-tr--index)
  }}
  <i class="fas fa-star" aria-hidden="true"></i>
{{/button}}
