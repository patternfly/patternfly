<button class="{{pfv}}table__button {{setModifiers table-button--IsPlain='pf-m-plain' table-button--modifier=table-button--modifier}}"
  {{#if table-button--attribute}}
    {{{table-button--attribute}}}
  {{/if}}>
  {{#if table-button--text}}
    {{{table-button--text}}}
  {{else if @partial-block}}
    {{> @partial-block}}
  {{/if}}
</button>
